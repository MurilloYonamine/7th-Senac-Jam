--- !u!114 &1888531281
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1888531279}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ef7532dd6c23992499cc30254530b15a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Seventh.View::Seventh.View.SlideshowCutscene
  _slides:
  - sprite: {fileID: 21300000, guid: 01885b98456feb14894a5abf82960690, type: 3}
    dialogueText: O Miau vaga por uma aventura genial, Uma caverna se torna seu alvo
      principal.
  - sprite: {fileID: 21300000, guid: 581d1270941af714eaa3c145a96e895c, type: 3}
    dialogueText: Junto com uma planta de aspecto incomum,
  - sprite: {fileID: 21300000, guid: 195fe9348b508924d87d751b7dfea339, type: 3}
    dialogueText: 'Que parecia apetitosa como nenhuma um.

'
  - sprite: {fileID: 21300000, guid: 05415e519b7f77b469dce7a51c1e38cc, type: 3}
    dialogueText: O miau fez aquilo de seu consumo.
  - sprite: {fileID: 21300000, guid: cb4b81c0e1e23c642830ca9b3246177d, type: 3}
    dialogueText: Mas o efeito daquilo...
  - sprite: {fileID: 21300000, guid: 6f5e340736e91f046ac157dd0de4c8d5, type: 3}
    dialogueText: Foi um veneno fatal.
  - sprite: {fileID: 21300000, guid: d80de9bf81b924e42ae0ed35638eae92, type: 3}
    dialogueText: "Uma dor estranha come\xE7ou a surgir..."
  - sprite: {fileID: 21300000, guid: 9345b884f2a119e4bad211037685dc1f, type: 3}
    dialogueText: "Ent\xE3o, uma gota vermelha tocou o ch\xE3o..."
  - sprite: {fileID: 21300000, guid: 31931c2e3fff4de48a3f9895807fef79, type: 3}
    dialogueText: "E logo o sangue formou uma po\xE7a sem fim."
  - sprite: {fileID: 21300000, guid: 8718394535e2a8448ba31ef38a301fda, type: 3}
    dialogueText: Em busca de uma cura, ele corre, o pobre animal,
  - sprite: {fileID: 21300000, guid: 8749133ff3605264393339482f9e6a5c, type: 3}
    dialogueText: Mas...
  - sprite: {fileID: 21300000, guid: 6f6f8e72325ec8641a0e7a04ddfa3528, type: 3}
    dialogueText: "Talvez n\xE3o seja t\xE3o f\xE1cil no final."
  _backgroundImage: {fileID: 2105763551}
  _dialogueTextElement: {fileID: 1436092742}
  _mainCanvasGroup: {fileID: 641647766}
  _advanceAction: {fileID: 1120369429361536294, guid: 2bcd2660ca9b64942af0de543d8d7100, type: 3}
  _charactersPerSecond: 30
  _canvasFadeDuration: 0.3
  _textFadeDuration: 0.5
  _onCutsceneStart:
    m_PersistentCalls:
      m_Calls: []
  _onCutsceneEnd:
    m_PersistentCalls:
      m_Calls: []
